datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------------------------------
// 1. NextAuth Core & Auth User
// ----------------------------------------------------------------------------

model User {
  id                    String        @id @default(uuid())
  name                  String?
  email                 String?       @unique
  emailVerified         DateTime?
  image                 String?
  role                  String        @default("USER") // USER, ADMIN
  paid                  Boolean       @default(false)
  pixReference          String?       // reference for the main registration
  paymentStatus         String        @default("PENDING_PAYMENT") // PENDING_PAYMENT, PENDING_APPROVAL, PAID
  points                Int           @default(0) // Global Ranking Points
  
  championTeamId        String?       // ID of selected champion team
  championTeam          Team?         @relation("UserChampion", fields: [championTeamId], references: [id])
  
  predictions           Prediction[]  // Global Guesses
  payments              Payment[]
  championPicks         ChampionPick[]
  
  accounts              Account[]
  sessions              Session[]

  // --- From NLW Copa (Private Groups) ---
  participatingAt       Participant[] 
  ownPolls              Poll[]

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([points])
  @@index([email])
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// 2. Bolão Global (Sports & Betting)
// ----------------------------------------------------------------------------

model Team {
  id                    String        @id // e.g. "BRA", "ARG", "FRA"
  name                  String
  flag                  String        // emoji or flag icon url
  eliminated            Boolean       @default(false)
  group                 String?       // A, B, C, D, etc.
  championUsers         User[]        @relation("UserChampion")
  championPicks         ChampionPick[]
  homeMatches           Match[]       @relation("HomeTeam")
  awayMatches           Match[]       @relation("AwayTeam")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model ChampionPick {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId                String
  team                  Team          @relation(fields: [teamId], references: [id])
  paymentId             String?
  active                Boolean       @default(true)
  buyback               Boolean       @default(false)
  createdAt             DateTime      @default(now())

  @@index([userId, active])
  @@index([teamId])
}

model Match { // Replaces NLW 'Game'
  id                    Int           @id // official match index/id
  externalId            Int?          // match ID from API
  homeTeamId            String
  awayTeamId            String
  homeTeam              Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam              Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore             Int?
  awayScore             Int?
  date                  DateTime      // Kickoff timestamp
  stage                 String        // GROUP, ROUND_OF_16, QUARTER_FINALS, SEMI_FINALS, THIRD_PLACE, FINAL
  isBrazilMatch         Boolean       @default(false)
  status                String        @default("SCHEDULED") // SCHEDULED, LIVE, FINISHED
  predictions           Prediction[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([date])
  @@index([status])
}

model Prediction { // Replaces NLW 'Guess'
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId               Int
  match                 Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore             Int
  awayScore             Int
  pointsEarned          Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  String        // REGISTRATION, CHAMPION_BUYBACK
  pixReference          String
  status                String        @default("PENDING") // PENDING, APPROVED, REJECTED
  amount                Float
  newChampionTeamId     String?       // For buyback: the new team selected if approved
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

// ----------------------------------------------------------------------------
// 3. Private Polls (NLW Copa)
// ----------------------------------------------------------------------------

model Poll {
  id        String   @id @default(cuid())
  title     String
  code      String   @unique
  createdAt DateTime @default(now())
  ownerId   String?

  participants Participant[]
  owner        User?         @relation(fields: [ownerId], references: [id])
}

model Participant {
  id     String @id @default(cuid())
  userId String
  pollId String

  user User @relation(fields: [userId], references: [id])
  poll Poll @relation(fields: [pollId], references: [id])

  @@unique([userId, pollId])
}
