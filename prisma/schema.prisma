datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String        @id @default(uuid())
  name                  String
  email                 String        @unique
  password              String
  role                  String        @default("USER") // USER, ADMIN
  paid                  Boolean       @default(false)
  pixReference          String?       // reference for the main R$ 50 registration
  paymentStatus         String        @default("PENDING_PAYMENT") // PENDING_PAYMENT, PENDING_APPROVAL, PAID
  points                Int           @default(0)
  championTeamId        String?       // ID of selected champion team
  championTeam          Team?         @relation("UserChampion", fields: [championTeamId], references: [id])
  predictions           Prediction[]
  payments              Payment[]
  championPicks         ChampionPick[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([points])
  @@index([email])
}

model Team {
  id                    String        @id // e.g. "BRA", "ARG", "FRA"
  name                  String
  flag                  String        // emoji or flag icon url
  eliminated            Boolean       @default(false)
  group                 String?       // A, B, C, D, etc.
  championUsers         User[]        @relation("UserChampion")
  championPicks         ChampionPick[]
  homeMatches           Match[]       @relation("HomeTeam")
  awayMatches           Match[]       @relation("AwayTeam")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model ChampionPick {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId                String
  team                  Team          @relation(fields: [teamId], references: [id])
  paymentId             String?
  active                Boolean       @default(true)
  buyback               Boolean       @default(false)
  createdAt             DateTime      @default(now())

  @@index([userId, active])
  @@index([teamId])
}

model Match {
  id                    Int           @id // official match index/id
  externalId            Int?          // match ID from API
  homeTeamId            String
  awayTeamId            String
  homeTeam              Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam              Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore             Int?
  awayScore             Int?
  date                  DateTime      // Kickoff timestamp
  stage                 String        // GROUP, ROUND_OF_16, QUARTER_FINALS, SEMI_FINALS, THIRD_PLACE, FINAL
  isBrazilMatch         Boolean       @default(false)
  status                String        @default("SCHEDULED") // SCHEDULED, LIVE, FINISHED
  predictions           Prediction[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([date])
  @@index([status])
}

model Prediction {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId               Int
  match                 Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore             Int
  awayScore             Int
  pointsEarned          Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  String        // REGISTRATION, CHAMPION_BUYBACK
  pixReference          String
  status                String        @default("PENDING") // PENDING, APPROVED, REJECTED
  amount                Float
  newChampionTeamId     String?       // For buyback: the new team selected if approved
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}
